#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
cd "$REPO_ROOT"

artifact="release-artifacts/jupiter_historian.wasm.gz"
deprecated_artifact="release-artifacts/jupiter_historian_with_relay.wasm.gz"
manifest="release-artifacts/release-artifacts.sha256"

if [[ ! -f "$manifest" ]]; then
  echo "missing canonical release artifact manifest: ${manifest}" >&2
  echo "run the sanctioned Docker build separately before this read-only preflight: ./tools/scripts/docker-build" >&2
  exit 1
fi

if [[ ! -f "$artifact" ]]; then
  echo "expected canonical relay-enabled historian artifact is missing: ${artifact}" >&2
  echo "run the sanctioned Docker build separately before this read-only preflight: ./tools/scripts/docker-build" >&2
  exit 1
fi

missing_manifest_artifacts=0
while read -r _hash path _rest; do
  [[ -z "${path:-}" ]] && continue
  if [[ ! -f "$path" ]]; then
    echo "manifest artifact is missing: ${path}" >&2
    missing_manifest_artifacts=1
  fi
done < "$manifest"
if [[ "$missing_manifest_artifacts" -ne 0 ]]; then
  echo "run the sanctioned Docker build separately before this read-only preflight: ./tools/scripts/docker-build" >&2
  exit 1
fi

sha256sum -c "$manifest"
python3 ./tools/scripts/validate-mainnet-install-args

echo
echo "Historian reinstall args must be complete:"
echo "canisters/historian/mainnet-install-args.did"

echo
echo "Production historian deploy artifact path:"
echo "$artifact"
echo
echo "Artifact hashes:"
cat release-artifacts/jupiter_historian.reviewed-relay-wasm-raw.sha256
cat release-artifacts/jupiter_historian.embedded-relay-wasm-gz.sha256
sha256sum "$artifact"

if [[ -f "$deprecated_artifact" ]]; then
  deprecated_hash="$(sha256sum "$deprecated_artifact" | awk '{print $1}')"
  canonical_hash="$(sha256sum "$artifact" | awk '{print $1}')"
  if [[ "$deprecated_hash" != "$canonical_hash" ]]; then
    echo "refusing preflight: deprecated historian-with-relay artifact exists with different bytes: ${deprecated_artifact}" >&2
    exit 1
  fi
fi

echo
echo "Dry-run only. Canonical release reinstall command after live controller-authority signoff:"
cat <<'CMD'
JUPITER_USE_CANONICAL_ARTIFACTS=1 \
icp deploy jupiter_historian \
  --environment ic \
  --mode reinstall \
  --args-file canisters/historian/mainnet-install-args.did
CMD
echo
echo "The command above resolves jupiter_historian through icp.yaml, which must build/copy:"
echo "$artifact"
