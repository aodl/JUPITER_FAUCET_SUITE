def fail(msg: str) -> None:
    print(f"mainnet install-args validation failed: {msg}", file=sys.stderr)
    sys.exit(1)


def require_contains(text: str, needle: str, context: str) -> None:
    if needle not in text:
        fail(f"{context} is missing `{needle}`")


def extract_nat64(text: str, field: str, path: Path) -> int:
    match = re.search(rf"{re.escape(field)}\s*=\s*(?:opt\s*)?(?:\()?\s*(\d+)(?:\s*:\s*nat64)?\s*\)?\s*;", text)
    if not match:
        fail(f"{path} is missing `{field}`")
    return int(match.group(1))


def extract_account(text: str, field: str, path: Path) -> tuple[str, str]:
    match = re.search(
        rf"{re.escape(field)}\s*=\s*(?:opt\s*)?record\s*\{{(?P<body>.*?)\}}\s*;",
        text,
        re.S,
    )
    if not match:
        fail(f"{path} is missing account `{field}`")
    body = match.group("body")
    owner = re.search(r'owner\s*=\s*principal\s+"([^"]+)"\s*;', body)
    subaccount = re.search(r"subaccount\s*=\s*(?P<value>[^;]+);", body)
    if not owner or not subaccount:
        fail(f"{path} has malformed account `{field}`")
    return owner.group(1), re.sub(r"\s+", " ", subaccount.group("value").strip())


def require_interval(text: str, field: str, expected: int, path: Path) -> None:
    value = extract_nat64(text, field, path)
    if value != expected:
        fail(f"{path} configures {field}={value}; expected {expected}")


def faucet_recognition_delay_error(text: str, path: Path) -> str | None:
    value = extract_nat64(text, "stake_recognition_delay_seconds", path)
    if value != EXPECTED_FAUCET_STAKE_RECOGNITION_DELAY_SECONDS:
        return (
            f"{path} configures stake_recognition_delay_seconds={value}; "
            f"expected {EXPECTED_FAUCET_STAKE_RECOGNITION_DELAY_SECONDS} "
            "(7 days, faucet-side recognition delay)"
        )
    return None


def require_faucet_recognition_delay(text: str, path: Path) -> None:
    recognition_delay_error = faucet_recognition_delay_error(text, path)
    if recognition_delay_error:
        fail(recognition_delay_error)


FORBIDDEN_PROD_DID_METHOD_PATTERNS = [
    r"\bdebug_\w+\b",
    r"\bforce_\w+\b",
    r"\bclear_active\w*\b",
    r"\binject_\w+\b",
    r"\btrap_\w+\b",
]


def validate_no_debug_methods_in_prod_did(path: Path) -> None:
    text = path.read_text()
    for pattern in FORBIDDEN_PROD_DID_METHOD_PATTERNS:
        match = re.search(pattern, text)
        if match:
            fail(f"{path} unexpectedly exposes debug-only method pattern `{match.group(0)}` in the production DID")


def validate_debug_methods_present_in_debug_did(path: Path) -> None:
    if not path.name.endswith("_debug.did"):
        fail(f"{path} debug DID must use the *_debug.did naming convention")
    text = path.read_text()
    if not re.search(r"\bdebug_\w+\b", text):
        fail(f"{path} is expected to expose debug_* methods")


def build_one_invocations(text: str) -> list[list[str]]:
    commands: list[list[str]] = []
    logical_line = ""
    for raw_line in text.splitlines():
        stripped = raw_line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if not logical_line and not stripped.startswith("build_one "):
            continue
        if stripped.endswith("\\"):
            logical_line += stripped[:-1] + " "
            continue
        logical_line += stripped
        try:
            parts = shlex.split(logical_line)
        except ValueError as exc:
            fail(f"tools/scripts/build-canister contains an unparsable shell command near `{logical_line}`: {exc}")
        if parts and parts[0] == "build_one":
            commands.append(parts)
        logical_line = ""
    if logical_line:
        try:
            parts = shlex.split(logical_line)
        except ValueError as exc:
            fail(f"tools/scripts/build-canister contains an unparsable shell command near `{logical_line}`: {exc}")
        if parts and parts[0] == "build_one":
            commands.append(parts)
    return commands


def validate_release_build_script_uses_release_dids() -> None:
    path = REPO_ROOT / "tools" / "scripts" / "build-canister"
    text = path.read_text()
    release_mappings = {
        "canisters/disburser/jupiter_disburser.did": "canisters/disburser/jupiter_disburser_debug.did",
        "canisters/faucet/jupiter_faucet.did": "canisters/faucet/jupiter_faucet_debug.did",
        "canisters/historian/jupiter_historian.did": "canisters/historian/jupiter_historian_debug.did",
        "canisters/relay/jupiter_relay.did": "canisters/relay/jupiter_relay_debug.did",
    }
    commands = build_one_invocations(text)
    for release_did, debug_did in release_mappings.items():
        if release_did not in text:
            fail(f"{path} is missing release DID mapping `{release_did}`")
        release_target = release_did.split("/")[1]
        matching_commands = [command for command in commands if release_target in " ".join(command)]
        if not matching_commands:
            fail(f"{path} is missing a build_one invocation for `{release_target}`")
        for command in matching_commands:
            command_text = " ".join(command)
            if debug_did in command or any(part.endswith("_debug.did") for part in command):
                fail(f"{path} uses debug DID in a release build_one mapping: `{command_text}`")


def icp_yaml_canister_block(text: str, canister_name: str) -> str | None:
    lines = text.splitlines()
    start = None
    start_indent = 0
    name_pattern = re.compile(rf"^(?P<indent>\s*)-\s+name:\s+{re.escape(canister_name)}\s*$")
    for idx, line in enumerate(lines):
        match = name_pattern.match(line)
        if match:
            start = idx
            start_indent = len(match.group("indent"))
            break
    if start is None:
        return None

    end = len(lines)
    next_canister_pattern = re.compile(rf"^\s{{{start_indent}}}-\s+name:\s+\S+")
    for idx in range(start + 1, len(lines)):
        if next_canister_pattern.match(lines[idx]):
            end = idx
            break
    return "\n".join(lines[start:end])


def icp_yaml_canister_has_init_args(text: str, canister_name: str) -> bool:
    block = icp_yaml_canister_block(text, canister_name)
    if block is None:
        fail(f"icp.yaml is missing canister entry `{canister_name}`")
    return re.search(r"(?m)^\s+init_args\s*:", block) is not None


def validate_icp_yaml_has_no_routine_prod_init_args() -> None:
    path = REPO_ROOT / "icp.yaml"
    text = path.read_text()
    for canister_name in ROUTINE_PROD_CANISTERS_WITHOUT_INIT_ARGS:
        if icp_yaml_canister_has_init_args(text, canister_name):
            fail(f"{path} must not wire init_args for routine production canister `{canister_name}`")


def icp_yaml_prod_artifact_error(text: str, canister_name: str, target: str, artifact_stem: str) -> str | None:
    block = icp_yaml_canister_block(text, canister_name)
    if block is None:
        return f"icp.yaml is missing canister entry `{canister_name}`"
    stale_uncompressed = rf"release-artifacts/{re.escape(artifact_stem)}\.wasm(?:\s|\"|$)"
    if re.search(stale_uncompressed, block):
        return f"icp.yaml production canister `{canister_name}` copies uncompressed `{artifact_stem}.wasm`"
    helper = f"./tools/scripts/icp-build-canister {target} {artifact_stem}"
    direct_copy = f'cp release-artifacts/{artifact_stem}.wasm.gz "$ICP_WASM_OUTPUT_PATH"'
    if helper not in block and direct_copy not in block:
        return (
            f"icp.yaml production canister `{canister_name}` must copy "
            f"`release-artifacts/{artifact_stem}.wasm.gz` to `$ICP_WASM_OUTPUT_PATH`"
        )
    return None


def validate_icp_yaml_uses_compressed_prod_artifacts() -> None:
    path = REPO_ROOT / "icp.yaml"
    text = path.read_text()
    for canister_name, (target, artifact_stem) in PROD_CANISTER_ARTIFACTS.items():
        error = icp_yaml_prod_artifact_error(text, canister_name, target, artifact_stem)
        if error:
            fail(error)


def validate_public_verifier_links() -> None:
    path = REPO_ROOT / "docs" / "operations" / "reproducible-builds.md"
    text = path.read_text()
    for url in REQUIRED_PUBLIC_VIEWS:
        require_contains(text, url, str(path))


def validate_relay_prod_did(path: Path) -> None:
    text = path.read_text()
    service_match = re.search(
        r"service\s*:\s*\(\s*InitArgs\s*\)\s*->\s*\{(?P<body>.*?)\}\s*$", text, re.S
    )
    if not service_match:
        fail(f"{path} relay production DID must expose a service")
    body = service_match.group("body")
    methods = set(re.findall(r"(?m)^\s*([A-Za-z_][A-Za-z0-9_]*)\s*:", body))
    if methods:
        fail(f"{path} relay production DID must expose an empty service, got methods {sorted(methods)}")
    forbidden = [
        "Relay" + "Status",
        "relay_" + "status",
        "admin_schedule_main_tick_now",
        "get_config",
        "get_last_summary",
        "get_last_cycles_samples",
        "Config",
        "RelaySummary",
        "CanisterBurnSample",
    ]
    for token in forbidden:
        if re.search(rf"\b{re.escape(token)}\b", text):
            fail(f"{path} unexpectedly contains relay production-only forbidden token `{token}`")
    forbidden_recipient_fields = [
        (r"\bcanister_id\s*:\s*opt\s+principal\b", "canister_id : opt principal"),
        (r"\bneuron_id\s*:\s*opt\s+nat64\b", "neuron_id : opt nat64"),
        (r"\bmemo\s*:\s*opt\s+blob\b", "memo : opt blob"),
        (r"\bsurplus_recipients\b", "surplus_recipients"),
    ]
    for pattern, field in forbidden_recipient_fields:
        if re.search(pattern, text):
            fail(f"{path} relay production DID must not expose old surplus recipient shape `{field}`")
    required_recipient_fields = [
        "type SurplusCanisterRecipient = record { canister_id : principal; memo : blob }",
        "type SurplusNeuronRecipient = record { neuron_id : nat64; memo : blob }",
        "surplus_canister_recipients : opt vec SurplusCanisterRecipient",
        "surplus_neuron_recipients : vec SurplusNeuronRecipient",
    ]
    for field in required_recipient_fields:
        if field not in text:
            fail(f"{path} relay production DID must expose split surplus recipient field `{field}`")
    if re.search(r"type\s+SurplusTarget\s*=", text):
        fail(f"{path} relay production DID must not expose SurplusTarget")


def validate_relay_debug_did(path: Path) -> None:
    text = path.read_text()
    expected = [
        "debug_main_tick",
        "debug_state",
        "debug_config",
        "debug_last_summary",
        "debug_set_cycles_sample",
        "debug_force_clear_active_job",
        "debug_abort_after_successful_transfer",
        "debug_trap_after_successful_transfer",
    ]
    for method in expected:
        if not re.search(rf"\b{re.escape(method)}\b", text):
            fail(f"{path} is missing debug relay method `{method}`")
    forbidden = [
        "Relay" + "Status",
        "relay_" + "status",
        "get_config",
        "get_last_summary",
        "get_last_cycles_samples",
        "admin_schedule_main_tick_now",
    ]
    for method in forbidden:
        if re.search(rf"\b{re.escape(method)}\b", text):
            fail(f"{path} unexpectedly exposes removed relay production method `{method}`")


def validate_relay_docs_and_smoke_are_log_only() -> None:
    forbidden = [
        "get_config",
        "get_last_summary",
        "get_last_cycles_samples",
        "relay_" + "status",
        "admin_schedule_main_tick_now",
    ]
    for path in [
        REPO_ROOT / "canisters" / "relay" / "README.md",
        REPO_ROOT / "tools" / "scripts" / "smoke-relay-mainnet",
    ]:
        text = path.read_text()
        for token in forbidden:
            if token in text:
                fail(f"{path} still mentions removed relay production endpoint `{token}`")

    relay_readme = (REPO_ROOT / "canisters" / "relay" / "README.md").read_text()
    require_contains(relay_readme, "blackhole_fiduciary_subnet", "canisters/relay/README.md")
    require_contains(relay_readme, MAINNET["blackhole"], "canisters/relay/README.md")
    require_contains(relay_readme, "blackhole_13_node_subnet", "canisters/relay/README.md")
    require_contains(
        relay_readme,
        MAINNET["blackhole_13_node_subnet"],
        "canisters/relay/README.md",
    )

    smoke = (REPO_ROOT / "tools" / "scripts" / "smoke-relay-mainnet").read_text()
    require_contains(smoke, MAINNET["blackhole"], "tools/scripts/smoke-relay-mainnet")
    require_contains(
        smoke,
        MAINNET["blackhole_13_node_subnet"],
        "tools/scripts/smoke-relay-mainnet",
    )


def validate_disburser() -> None:
    path = REPO_ROOT / "canisters" / "disburser" / "mainnet-install-args.did"
    text = path.read_text()
    require_contains(text, 'neuron_id = 11614578985374291210 : nat64;', str(path))
    require_contains(text, f'owner = principal "{PROD["jupiter_faucet"]}";', str(path))
    require_contains(text, f'owner = principal "{PROD["jupiter_sns_rewards"]}";', str(path))
    require_contains(text, f'owner = principal "{MAINNET["governance"]}";', str(path))
    require_contains(text, f'subaccount = {EXPECTED_DQUORUM_SUBACCOUNT};', str(path))
    require_contains(text, f'ledger_canister_id = opt principal "{MAINNET["ledger"]}";', str(path))
    require_contains(text, f'governance_canister_id = opt principal "{MAINNET["governance"]}";', str(path))
    require_contains(text, f'rescue_controller = principal "{PROD["jupiter_lifeline"]}";', str(path))
    require_contains(text, f'blackhole_controller = opt principal "{MAINNET["blackhole"]}";', str(path))
    require_interval(text, "main_interval_seconds", 86400, path)
    require_interval(text, "rescue_interval_seconds", 86400, path)


def validate_faucet() -> int:
    path = REPO_ROOT / "canisters" / "faucet" / "mainnet-install-args.did"
    text = path.read_text()
    require_contains(text, f'owner = principal "{MAINNET["governance"]}";', str(path))
    require_contains(text, f'subaccount = {EXPECTED_STAKING_SUBACCOUNT};', str(path))
    require_contains(text, f'ledger_canister_id = opt principal "{MAINNET["ledger"]}";', str(path))
    require_contains(text, f'index_canister_id = opt principal "{MAINNET["index"]}";', str(path))
    require_contains(text, f'cmc_canister_id = opt principal "{MAINNET["cmc"]}";', str(path))
    require_contains(text, f'rescue_controller = principal "{PROD["jupiter_lifeline"]}";', str(path))
    require_contains(text, f'blackhole_controller = opt principal "{MAINNET["blackhole"]}";', str(path))
    require_contains(text, f'funding_source_account = record {{', str(path))
    require_contains(text, f'owner = principal "{PROD["jupiter_disburser"]}";', str(path))
    require_interval(text, "main_interval_seconds", 86400, path)
    require_interval(text, "rescue_interval_seconds", 86400, path)
    require_faucet_recognition_delay(text, path)

    match = re.search(r"expected_first_staking_tx_id\s*=\s*([^;]+);", text)
    if not match:
        fail(f"{path} is missing `expected_first_staking_tx_id`")
    value = match.group(1).strip()
    faucet_min_tx_e8s = extract_nat64(text, "min_tx_e8s", path)
    if faucet_min_tx_e8s < 10_000_000:
        fail(f"{path} configures min_tx_e8s below the supported floor of 10_000_000 e8s (0.1 ICP)")
    if value == "null":
        return faucet_min_tx_e8s
    if re.fullmatch(r"opt\s+\(?\s*\d+(?:\s*:\s*nat64)?\s*\)?", value):
        return faucet_min_tx_e8s
    fail(
        f"{path} has invalid `expected_first_staking_tx_id` value `{value}`; expected `null` or `opt <nat64>`"
    )


def faucet_upgrade_example_uses_install_args(text: str) -> bool:
    install_args = r"canisters/faucet/mainnet-install-args\.did"
    patterns = [
        rf"icp canister install jupiter_faucet[\s\S]{{0,300}}--mode\s+upgrade[\s\S]{{0,300}}{install_args}",
        rf"icp canister install jupiter_faucet[\s\S]{{0,300}}{install_args}[\s\S]{{0,300}}--mode\s+upgrade",
    ]
    return any(re.search(pattern, text) for pattern in patterns)


def docs_use_install_args_for_upgrade(text: str) -> bool:
    return re.search(
        r"icp (?:canister install|deploy) \S+[\s\S]{0,400}--mode\s+upgrade[\s\S]{0,400}mainnet-install-args\.did",
        text,
    ) is not None or re.search(
        r"icp (?:canister install|deploy) \S+[\s\S]{0,400}mainnet-install-args\.did[\s\S]{0,400}--mode\s+upgrade",
        text,
    ) is not None


def docs_recommend_explicit_null_for_routine_upgrade(text: str) -> bool:
    forbidden_phrases = [
        "Routine production upgrades with no config change should pass explicit "
        "`null` upgrade args",
        "Routine faucet upgrades with no config change should pass explicit "
        "`null` upgrade args",
    ]
    if any(phrase in text for phrase in forbidden_phrases):
        return True
    return re.search(r"--args\s+['\"]\(null\)['\"]", text) is not None


def docs_recommend_direct_install_for_prod_deploy(text: str) -> bool:
    return re.search(
        r"(?m)^\s*icp canister install \S+[\s\S]{0,300}(?:--network|--environment)\s+ic[\s\S]{0,300}--wasm\s+release-artifacts/\S+\.wasm\.gz",
        text,
    ) is not None


def docs_use_stale_privileged_deployment_framing(text: str) -> bool:
    return "Production deployment is a manual, privileged operation." in text


def validate_upgrade_docs_do_not_use_install_args_or_null_routine_args() -> None:
    for path in [
        REPO_ROOT / "README.md",
        REPO_ROOT / "canisters" / "disburser" / "README.md",
        REPO_ROOT / "canisters" / "faucet" / "README.md",
        REPO_ROOT / "canisters" / "historian" / "README.md",
        REPO_ROOT / "canisters" / "relay" / "README.md",
        REPO_ROOT / "tools" / "xtask" / "src" / "main.rs",
    ]:
        text = path.read_text()
        if faucet_upgrade_example_uses_install_args(text):
            fail(f"{path} documents faucet upgrade with mainnet-install-args.did; use appropriate UpgradeArgs instead")
        if docs_use_install_args_for_upgrade(text):
            fail(f"{path} documents upgrade with mainnet-install-args.did; install args are fresh install/reinstall only")
        if docs_recommend_explicit_null_for_routine_upgrade(text):
            fail(f"{path} recommends explicit null args for a routine production upgrade; use icp deploy without args")
        if docs_recommend_direct_install_for_prod_deploy(text):
            fail(f"{path} documents direct production install as the preferred path; use icp deploy --environment ic")


def validate_docs_do_not_use_stale_privileged_deployment_framing() -> None:
    for path in [
        REPO_ROOT / "README.md",
        REPO_ROOT / "docs" / "operations" / "deployment.md",
        REPO_ROOT / "docs" / "operations" / "reproducible-builds.md",
    ]:
        text = path.read_text()
        if docs_use_stale_privileged_deployment_framing(text):
            fail(f"{path} uses stale privileged deployment framing; describe SNS governance control and bootstrap execution")


def validate_historian() -> int:
    path = REPO_ROOT / "canisters" / "historian" / "mainnet-install-args.did"
    text = path.read_text()
    require_contains(text, f'owner = principal "{MAINNET["governance"]}";', str(path))
    require_contains(text, f'subaccount = {EXPECTED_STAKING_SUBACCOUNT};', str(path))
    require_contains(text, f'ledger_canister_id = opt principal "{MAINNET["ledger"]}";', str(path))
    require_contains(text, f'index_canister_id = opt principal "{MAINNET["index"]}";', str(path))
    require_contains(text, f'cmc_canister_id = opt principal "{MAINNET["cmc"]}";', str(path))
    require_contains(text, f'faucet_canister_id = opt principal "{PROD["jupiter_faucet"]}";', str(path))
    require_contains(text, f'blackhole_canister_id = opt principal "{MAINNET["blackhole"]}";', str(path))
    require_contains(text, f'sns_wasm_canister_id = opt principal "{MAINNET["sns_wasm"]}";', str(path))
    historian_min_tx_e8s = extract_nat64(text, "min_tx_e8s", path)
    if historian_min_tx_e8s < 10_000_000:
        fail(f"{path} configures min_tx_e8s below the supported floor of 10_000_000 e8s (0.1 ICP)")
    return historian_min_tx_e8s


def extract_vec_principals(text: str, field: str, path: Path) -> list[str]:
    match = re.search(rf"{re.escape(field)}\s*=\s*vec\s*\{{(?P<body>.*?)\}}\s*;", text, re.S)
    if not match:
        fail(f"{path} is missing `{field}`")
    return re.findall(r'principal\s+"([^"]+)"', match.group("body"))


def require_opt_principal(text: str, field: str, expected: str, path: Path) -> None:
    require_contains(text, f'{field} = opt principal "{expected}";', str(path))


def normalize_nat_literal(value: str) -> str:
    return re.sub(r"[_\s]", "", value)


def decode_candid_blob_string(value: str) -> bytes:
    out = bytearray()
    i = 0
    while i < len(value):
        if value[i] == "\\" and i + 2 < len(value) and re.fullmatch(r"[0-9a-fA-F]{2}", value[i + 1 : i + 3]):
            out.append(int(value[i + 1 : i + 3], 16))
            i += 3
        else:
            out.extend(value[i].encode("utf-8"))
            i += 1
    return bytes(out)


def relay_surplus_recipient_errors(text: str, path: Path) -> list[str]:
    errors = []
    if re.search(r"\braw_icp_mode\b", text):
        errors.append(f"{path} must not contain removed raw_icp_mode")
    if re.search(r"\bsurplus_recipients\s*=", text):
        errors.append(f"{path} must not contain old surplus_recipients")
    if not re.search(r"surplus_canister_recipients\s*=\s*null\s*;", text):
        errors.append(f"{path} must set current production surplus_canister_recipients = null")
    if not re.search(r"surplus_neuron_recipients\s*=\s*vec\s*\{", text):
        errors.append(f"{path} must configure surplus_neuron_recipients")
        return errors

    recipients = re.findall(
        r"record\s*\{(?P<body>.*?)"
        r"neuron_id\s*=\s*(?P<neuron>[0-9_\s]+)\s*:\s*nat64\s*;\s*"
        r"memo\s*=\s*blob\s+\"(?P<blob>(?:\\.|[^\"])*)\"\s*;(?P<trailing>.*?)\}",
        text,
        re.S,
    )
    by_neuron = {}
    for _, neuron, blob, _ in recipients:
        by_neuron[normalize_nat_literal(neuron)] = decode_candid_blob_string(blob)

    if len(by_neuron) != 2:
        errors.append(f"{path} production surplus_neuron_recipients must contain exactly two neurons")

    if EXPECTED_RELAY_IO_NEURON_CANONICAL not in by_neuron:
        errors.append(f"{path} must route production surplus to the IO neuron")
    else:
        memo = by_neuron[EXPECTED_RELAY_IO_NEURON_CANONICAL]
        if memo != b"":
            errors.append(f"{path} IO surplus recipient memo must be blob \"\"")
    if EXPECTED_RELAY_JUPITER_FAUCET_NEURON_CANONICAL not in by_neuron:
        errors.append(f"{path} must route production surplus to the Jupiter Faucet neuron")
        return errors

    memo = by_neuron[EXPECTED_RELAY_JUPITER_FAUCET_NEURON_CANONICAL]
    if memo != EXPECTED_RELAY_IO_NEURON_CANONICAL.encode("ascii"):
        errors.append(f"{path} Jupiter Faucet surplus recipient memo must encode IO neuron {EXPECTED_RELAY_IO_NEURON_CANONICAL}")
    return errors


def validate_relay() -> None:
    if "jupiter_relay" not in CANISTER_IDS:
        fail(".icp/data/mappings/ic.ids.json is missing jupiter_relay")
    if PROD["jupiter_relay"] != EXPECTED_RELAY_ID:
        fail(
            ".icp/data/mappings/ic.ids.json has wrong jupiter_relay "
            f"{PROD['jupiter_relay']} expected {EXPECTED_RELAY_ID}"
        )
    path = REPO_ROOT / "canisters" / "relay" / "mainnet-install-args.did"
    if not path.exists():
        fail(f"{path} is missing")
    text = path.read_text()

    require_opt_principal(text, "ledger_canister_id", MAINNET["ledger"], path)
    require_opt_principal(text, "cmc_canister_id", MAINNET["cmc"], path)
    require_opt_principal(text, "governance_canister_id", MAINNET["governance"], path)
    require_opt_principal(text, "blackhole_canister_id", MAINNET["blackhole"], path)
    require_interval(text, "main_interval_seconds", 86400, path)
    compact_relay_memo = f"{PROD['jupiter_relay'].replace('-', '')}.Relay"
    if compact_relay_memo != EXPECTED_RELAY_JUPITER_FAUCET_COMMITMENT_MEMO:
        fail(
            "production relay compact Faucet commitment memo mismatch: "
            f"got {compact_relay_memo} expected {EXPECTED_RELAY_JUPITER_FAUCET_COMMITMENT_MEMO}"
        )
    if len(compact_relay_memo.encode("ascii")) > 32:
        fail(f"production relay compact Faucet commitment memo exceeds 32 bytes: {compact_relay_memo}")

    managed = extract_vec_principals(text, "managed_canisters", path)
    if len(managed) != len(set(managed)):
        fail(f"{path} has duplicate managed_canisters")
    managed_set = set(managed)
    if managed_set != EXPECTED_RELAY_MANAGED:
        fail(
            f"{path} managed_canisters mismatch: got {sorted(managed_set)} "
            f"expected {sorted(EXPECTED_RELAY_MANAGED)}"
        )
    forbidden = sorted(managed_set & FORBIDDEN_RELAY_MANAGED)
    if forbidden:
        fail(f"{path} managed_canisters contains forbidden system/self principal(s): {forbidden}")

    max_match = re.search(r"max_transfers_per_tick\s*=\s*(?P<value>[^;]+);", text)
    if max_match:
        value = max_match.group("value").strip()
        if value != "null":
            number = re.search(r"(\d+)", value)
            if not number or int(number.group(1)) <= 0:
                fail(f"{path} max_transfers_per_tick must be absent/null or greater than zero")

    errors = relay_surplus_recipient_errors(text, path)
    if errors:
        fail(errors[0])


def run_self_tests() -> None:
    path = Path("relay-test.did")
    valid = f'''
    surplus_canister_recipients = null;
    surplus_neuron_recipients = vec {{
      record {{
        neuron_id = {EXPECTED_RELAY_IO_NEURON} : nat64;
        memo = blob "";
      }};
      record {{
        neuron_id = {EXPECTED_RELAY_JUPITER_FAUCET_NEURON} : nat64;
        memo = blob "{EXPECTED_RELAY_IO_NEURON_CANONICAL}";
      }};
    }};
    '''
    missing_io = valid.replace(
        f"neuron_id = {EXPECTED_RELAY_IO_NEURON} : nat64",
        "neuron_id = 1 : nat64",
    )
    missing_jupiter = valid.replace(
        f"neuron_id = {EXPECTED_RELAY_JUPITER_FAUCET_NEURON} : nat64",
        "neuron_id = 2 : nat64",
    )
    missing_memo = valid.replace(
        f'memo = blob "{EXPECTED_RELAY_IO_NEURON_CANONICAL}";',
        'memo = blob "";',
    )
    wrong_memo = valid.replace(
        f'memo = blob "{EXPECTED_RELAY_IO_NEURON_CANONICAL}";',
        'memo = blob "1";',
    )
    old_shape = valid.replace(
        "surplus_neuron_recipients = vec",
        "surplus_recipients = vec",
        1,
    )
    missing_canister_null = valid.replace(
        "surplus_canister_recipients = null;",
        "surplus_canister_recipients = opt vec {};",
        1,
    )
    escaped_memo = valid.replace(
        f'"{EXPECTED_RELAY_IO_NEURON_CANONICAL}"',
        r'"\36\33\34\35\38\39\30\38\38\36\38\39\39\33\31\37\31\35\39"',
    )

    cases = [
        (valid, False, "valid relay surplus recipients"),
        (escaped_memo, False, "escaped IO neuron memo"),
        (old_shape, True, "old relay recipient field"),
        (missing_canister_null, True, "non-null production canister recipient field"),
        (missing_io, True, "missing IO neuron recipient"),
        (missing_jupiter, True, "missing Jupiter Faucet neuron recipient"),
        (missing_memo, True, "missing Jupiter Faucet IO memo"),
        (wrong_memo, True, "wrong Jupiter Faucet IO memo"),
    ]
    for body, should_error, label in cases:
        errors = relay_surplus_recipient_errors(body, path)
        if should_error and not errors:
            fail(f"self-test failed to reject {label}")
        if not should_error and errors:
            fail(f"self-test unexpectedly rejected {label}: {errors[0]}")

    faucet_path = REPO_ROOT / "canisters" / "faucet" / "mainnet-install-args.did"
    valid_faucet_delay = "stake_recognition_delay_seconds = opt 604800;"
    stale_faucet_delay = "stake_recognition_delay_seconds = opt 86400;"
    if faucet_recognition_delay_error(valid_faucet_delay, faucet_path):
        fail("self-test unexpectedly rejected production 7-day faucet recognition delay")
    if faucet_recognition_delay_error(stale_faucet_delay, faucet_path) is None:
        fail("self-test failed to reject stale 1-day faucet recognition delay")
    bad_upgrade_example_mode_first = """
    icp canister install jupiter_faucet \
      --environment ic \
      --mode upgrade \
      --args-file canisters/faucet/mainnet-install-args.did \
      --yes
    """
    bad_upgrade_example_args_first = """
    icp canister install jupiter_faucet \
      --environment ic \
      --args-file canisters/faucet/mainnet-install-args.did \
      --mode upgrade \
      --yes
    """
    reinstall_example = bad_upgrade_example_mode_first.replace("--mode upgrade", "--mode reinstall")
    if not faucet_upgrade_example_uses_install_args(bad_upgrade_example_mode_first):
        fail("self-test failed to reject faucet upgrade example using install args after --mode upgrade")
    if not faucet_upgrade_example_uses_install_args(bad_upgrade_example_args_first):
        fail("self-test failed to reject faucet upgrade example using install args before --mode upgrade")
    if faucet_upgrade_example_uses_install_args(reinstall_example):
        fail("self-test unexpectedly rejected fresh-only faucet reinstall example using install args")
    if not docs_use_install_args_for_upgrade(bad_upgrade_example_mode_first):
        fail("self-test failed to reject generic upgrade example using install args after --mode upgrade")
    if not docs_use_install_args_for_upgrade(bad_upgrade_example_args_first):
        fail("self-test failed to reject generic upgrade example using install args before --mode upgrade")
    if docs_use_install_args_for_upgrade(reinstall_example):
        fail("self-test unexpectedly rejected generic fresh-only reinstall example using install args")

    routine_null_text = (
        "Routine production upgrades with no config change should pass explicit "
        "`null` upgrade args:\n"
        "--args " + "'(null)'"
    )
    if not docs_recommend_explicit_null_for_routine_upgrade(routine_null_text):
        fail("self-test failed to reject routine upgrade explicit null guidance")
    routine_deploy_text = "Routine production upgrades should use:\nicp deploy jupiter_faucet --environment ic"
    if docs_recommend_explicit_null_for_routine_upgrade(routine_deploy_text):
        fail("self-test unexpectedly rejected routine deploy guidance")

    direct_install_text = """
    icp canister install jupiter_faucet \
      --environment ic \
      --mode upgrade \
      --wasm release-artifacts/jupiter_faucet.wasm.gz
    """
    if not docs_recommend_direct_install_for_prod_deploy(direct_install_text):
        fail("self-test failed to reject direct production install guidance")
    stale_privileged_text = "Production deployment is a manual, privileged operation."
    bootstrap_governance_text = (
        "During the initial bootstrap phase, upgrades may still be executed by "
        "the current bootstrap controller. Once Jupiter Faucet is under SNS DAO "
        "control, production upgrades are expected to pass through SNS community consensus."
    )
    if not docs_use_stale_privileged_deployment_framing(stale_privileged_text):
        fail("self-test failed to reject stale privileged deployment framing")
    if docs_use_stale_privileged_deployment_framing(bootstrap_governance_text):
        fail("self-test unexpectedly rejected bootstrap-scoped governance wording")

    icp_yaml_without_init_args = """
canisters:
  - name: jupiter_faucet
    build:
      steps: []
  - name: jupiter_disburser
    build:
      steps: []
  - name: jupiter_historian
    build:
      steps: []
  - name: jupiter_relay
    build:
      steps: []
    """
    for canister_name in ROUTINE_PROD_CANISTERS_WITHOUT_INIT_ARGS:
        if icp_yaml_canister_has_init_args(icp_yaml_without_init_args, canister_name):
            fail(f"self-test unexpectedly found init_args in clean {canister_name} block")
        icp_yaml_with_init_args = icp_yaml_without_init_args.replace(
            f"  - name: {canister_name}\n    build:",
            f"  - name: {canister_name}\n    init_args:\n      path: {canister_name}/mainnet-install-args.did\n    build:",
            1,
        )
        if not icp_yaml_canister_has_init_args(icp_yaml_with_init_args, canister_name):
            fail(f"self-test failed to reject init_args in {canister_name} block")

    valid_icp_yaml = """
canisters:
  - name: jupiter_faucet
    build:
      steps:
        - type: script
          commands:
            - ./tools/scripts/icp-build-canister jupiter-faucet jupiter_faucet
    """
    stale_icp_yaml = valid_icp_yaml.replace(
        "./tools/scripts/icp-build-canister jupiter-faucet jupiter_faucet",
        'cp release-artifacts/jupiter_faucet.wasm "$ICP_WASM_OUTPUT_PATH"',
    )
    missing_icp_yaml = valid_icp_yaml.replace(
        "./tools/scripts/icp-build-canister jupiter-faucet jupiter_faucet",
        "echo build elsewhere",
    )
    wrong_stem_icp_yaml = valid_icp_yaml.replace(
        "./tools/scripts/icp-build-canister jupiter-faucet jupiter_faucet",
        "./tools/scripts/icp-build-canister jupiter-faucet wrong_artifact",
    )
    if icp_yaml_prod_artifact_error(valid_icp_yaml, "jupiter_faucet", "jupiter-faucet", "jupiter_faucet"):
        fail("self-test unexpectedly rejected compressed icp.yaml production artifact path")
    if not icp_yaml_prod_artifact_error(stale_icp_yaml, "jupiter_faucet", "jupiter-faucet", "jupiter_faucet"):
        fail("self-test failed to reject uncompressed icp.yaml production artifact path")
    if not icp_yaml_prod_artifact_error(missing_icp_yaml, "jupiter_faucet", "jupiter-faucet", "jupiter_faucet"):
        fail("self-test failed to reject missing icp.yaml compressed production artifact path")
    if icp_yaml_canister_block(wrong_stem_icp_yaml, "jupiter_faucet") is None:
        fail("self-test malformed wrong-stem icp.yaml fixture by removing the canister block")
    if not icp_yaml_prod_artifact_error(wrong_stem_icp_yaml, "jupiter_faucet", "jupiter-faucet", "jupiter_faucet"):
        fail("self-test failed to reject wrong icp.yaml artifact stem")
    print("validate-mainnet-install-args self-tests OK")


def main() -> None:
    disburser_text = (REPO_ROOT / "canisters" / "disburser" / "mainnet-install-args.did").read_text()
    faucet_text = (REPO_ROOT / "canisters" / "faucet" / "mainnet-install-args.did").read_text()
    disburser_normal_recipient = extract_account(
        disburser_text,
        "normal_recipient",
        REPO_ROOT / "canisters" / "disburser" / "mainnet-install-args.did",
    )
    faucet_payout_account = (PROD["jupiter_faucet"], "null")
    faucet_funding_source = extract_account(
        faucet_text,
        "funding_source_account",
        REPO_ROOT / "canisters" / "faucet" / "mainnet-install-args.did",
    )
    faucet_staking_account = extract_account(
        faucet_text,
        "staking_account",
        REPO_ROOT / "canisters" / "faucet" / "mainnet-install-args.did",
    )
    if disburser_normal_recipient != faucet_payout_account:
        fail(
            "disburser normal_recipient must equal faucet payout account: "
            f"got {disburser_normal_recipient}, expected {faucet_payout_account}"
        )
    if faucet_funding_source != (PROD["jupiter_disburser"], "null"):
        fail(
            "faucet funding_source_account must equal disburser default account: "
            f"got {faucet_funding_source}"
        )
    if faucet_staking_account != (MAINNET["governance"], EXPECTED_STAKING_SUBACCOUNT):
        fail(f"faucet staking_account mismatch: got {faucet_staking_account}")

    validate_disburser()
    faucet_min_tx_e8s = validate_faucet()
    validate_icp_yaml_has_no_routine_prod_init_args()
    validate_icp_yaml_uses_compressed_prod_artifacts()
    validate_public_verifier_links()
    validate_upgrade_docs_do_not_use_install_args_or_null_routine_args()
    validate_docs_do_not_use_stale_privileged_deployment_framing()
    historian_min_tx_e8s = validate_historian()
    validate_relay()
    validate_release_build_script_uses_release_dids()
    if faucet_min_tx_e8s != historian_min_tx_e8s:
        fail(
            f"faucet/historian min_tx_e8s mismatch: faucet={faucet_min_tx_e8s} historian={historian_min_tx_e8s}"
        )

    validate_no_debug_methods_in_prod_did(REPO_ROOT / "canisters" / "faucet" / "jupiter_faucet.did")
    validate_no_debug_methods_in_prod_did(REPO_ROOT / "canisters" / "disburser" / "jupiter_disburser.did")
    validate_no_debug_methods_in_prod_did(REPO_ROOT / "canisters" / "historian" / "jupiter_historian.did")
    validate_no_debug_methods_in_prod_did(REPO_ROOT / "canisters" / "relay" / "jupiter_relay.did")
    validate_relay_prod_did(REPO_ROOT / "canisters" / "relay" / "jupiter_relay.did")
    validate_debug_methods_present_in_debug_did(REPO_ROOT / "canisters" / "faucet" / "jupiter_faucet_debug.did")
    validate_debug_methods_present_in_debug_did(REPO_ROOT / "canisters" / "disburser" / "jupiter_disburser_debug.did")
    validate_debug_methods_present_in_debug_did(REPO_ROOT / "canisters" / "historian" / "jupiter_historian_debug.did")
    validate_debug_methods_present_in_debug_did(REPO_ROOT / "canisters" / "relay" / "jupiter_relay_debug.did")
    validate_relay_debug_did(REPO_ROOT / "canisters" / "relay" / "jupiter_relay_debug.did")
    validate_relay_docs_and_smoke_are_log_only()
    print("mainnet install-args and DID validation OK")


if __name__ == "__main__":
    if len(sys.argv) == 2 and sys.argv[1] == "--self-test":
        run_self_tests()
    else:
        main()
