#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

cd "$REPO_ROOT"

if ! command -v docker >/dev/null 2>&1; then
  echo "docker is required to verify reproducible release artifacts" >&2
  exit 1
fi

if ! docker buildx version >/dev/null 2>&1; then
  echo "docker buildx is required to verify reproducible release artifacts" >&2
  exit 1
fi

workdir="$(mktemp -d)"
cleanup() {
  rm -rf "$workdir"
}
trap cleanup EXIT

docker buildx build \
  --platform linux/amd64 \
  --no-cache \
  --file Dockerfile.repro \
  --target artifact \
  --output "type=local,dest=$workdir/run-a" \
  .

docker buildx build \
  --platform linux/amd64 \
  --no-cache \
  --file Dockerfile.repro \
  --target artifact \
  --output "type=local,dest=$workdir/run-b" \
  .

(
  cd "$workdir/run-a"
  find . -type f -print0 | sort -z | xargs -0 sha256sum
) > "$workdir/run-a.sha256"
(
  cd "$workdir/run-b"
  find . -type f -print0 | sort -z | xargs -0 sha256sum
) > "$workdir/run-b.sha256"

if ! diff -u "$workdir/run-a.sha256" "$workdir/run-b.sha256"; then
  echo "release artifacts differ between clean same-environment rebuilds" >&2
  exit 1
fi

echo "release artifacts match across clean same-environment rebuilds"
