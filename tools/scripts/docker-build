#!/usr/bin/env bash
set -euo pipefail

command -v docker >/dev/null 2>&1 || {
  echo "docker is required but not installed or not on PATH" >&2
  exit 1
}

docker buildx version >/dev/null 2>&1 || {
  echo "docker buildx is required but not available" >&2
  exit 1
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

cd "$REPO_ROOT"

rm -rf release-artifacts .repro-out
mkdir -p .repro-out release-artifacts

docker buildx build   --platform linux/amd64   --target artifact   --output type=local,dest=./.repro-out   -f Dockerfile.repro   .

if [ -d ./.repro-out/release-artifacts ]; then
  cp -a ./.repro-out/release-artifacts/. ./release-artifacts/
else
  cp -a ./.repro-out/. ./release-artifacts/
fi

rm -rf .repro-out

echo
echo "Built canonical artifact(s):"
find release-artifacts -maxdepth 2 -type f | sort

manifest="release-artifacts/release-artifacts.sha256"
manifest_tmp="$(mktemp)"
find release-artifacts \
  -maxdepth 2 \
  -type f \
  ! -name 'release-artifacts.sha256' \
  \( -name '*.wasm' -o -name '*.wasm.gz' -o -name '*.sha256' -o -name 'build-info.json' \) \
  -print0 |
  sort -z |
  xargs -0 sha256sum > "$manifest_tmp"
mv "$manifest_tmp" "$manifest"

echo
echo "Release artifact manifest:"
cat "$manifest"

echo
for wasm in release-artifacts/*.wasm; do
  [ -e "$wasm" ] || continue
  echo "Decompressed Wasm hash ($(basename "$wasm")):"
  sha256sum "$wasm"
  echo
done

for wasm_gz in release-artifacts/*.wasm.gz; do
  [ -e "$wasm_gz" ] || continue
  echo "Installed package hash ($(basename "$wasm_gz")):"
  sha256sum "$wasm_gz"
  echo
done
