#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

cd "$REPO_ROOT"

export TZ=UTC
export LC_ALL=C.UTF-8
export LANG=C.UTF-8

if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  export SOURCE_DATE_EPOCH="${SOURCE_DATE_EPOCH:-$(git log -1 --pretty=%ct)}"
else
  export SOURCE_DATE_EPOCH="${SOURCE_DATE_EPOCH:-1700000000}"
fi

export RUSTFLAGS="${RUSTFLAGS:-} --remap-path-prefix=${REPO_ROOT}=/build"

mkdir -p release-artifacts

FRONTEND_ASSET_TOKEN="__ASSET_VERSION__"
FRONTEND_BUNDLE_TOKEN="__APP_BUNDLE_PATH__"
FRONTEND_BUNDLE_MANIFEST="jupiter-faucet-frontend/assets/generated/frontend-bundle.json"
FRONTEND_RENDER_TMP=""
declare -a FRONTEND_RENDERED_FILES=()

ensure_frontend_node_modules() {
  if ! command -v npm >/dev/null 2>&1; then
    echo "npm is required to build the frontend bundle" >&2
    exit 1
  fi

  if [[ ! -f package-lock.json ]]; then
    echo "package-lock.json is required for reproducible frontend builds" >&2
    exit 1
  fi

  local needs_install=0
  if [[ ! -d node_modules ]]; then
    needs_install=1
  elif ! npm ls --depth=0 @icp-sdk/core @noble/hashes esbuild >/dev/null 2>&1; then
    needs_install=1
  fi

  if [[ "$needs_install" -eq 1 ]]; then
    npm ci --no-fund --no-audit
  fi
}

build_frontend_bundle() {
  ensure_frontend_node_modules
  npm run build:frontend
}

compute_asset_version() {
  if [[ -n "${ASSET_VERSION:-}" ]]; then
    printf '%s\n' "$ASSET_VERSION"
    return
  fi

  python3 - <<'PY'
from pathlib import Path
import hashlib

# This is a single frontend-wide cache-busting token, not a per-file hash.
# We intentionally version all static asset URLs together so any relevant
# frontend/build input change forces clients onto a coherent asset set.
# The generated JS bundle is additionally content-addressed by filename.
# Note: test and build-script changes are included on purpose as part of
# this coarse-grained invalidation strategy.
roots = [
    Path('jupiter-faucet-frontend/assets'),
    Path('jupiter-faucet-frontend/assets/generated'),
    Path('jupiter-faucet-frontend/frontend-src/src'),
    Path('jupiter-faucet-frontend/frontend-src/test'),
    Path('jupiter-faucet-frontend/frontend-src/build-frontend.mjs'),
    Path('scripts/build-canister'),
]

h = hashlib.sha256()
for root in roots:
    if not root.exists():
        continue
    paths = sorted(root.rglob('*')) if root.is_dir() else [root]
    for path in paths:
        if not path.is_file():
            continue
        rel = path.as_posix().encode('utf-8')
        h.update(rel)
        h.update(b'\0')
        h.update(path.read_bytes())
        h.update(b'\0')

print(f"frontend-{h.hexdigest()[:12]}")
PY
}

render_frontend_assets() {
  local asset_version bundle_path
  asset_version="$(compute_asset_version)"

  if [[ ! -f "$FRONTEND_BUNDLE_MANIFEST" ]]; then
    echo "missing frontend bundle manifest: $FRONTEND_BUNDLE_MANIFEST" >&2
    exit 1
  fi

  bundle_path="$(python3 - <<'PY'
from pathlib import Path
import json
manifest = json.loads(Path('jupiter-faucet-frontend/assets/generated/frontend-bundle.json').read_text())
print(manifest['bundlePath'])
PY
)"

  echo "Using jupiter-faucet-frontend asset version: ${asset_version}"
  echo "Using jupiter-faucet-frontend bundle path: ${bundle_path}"

  FRONTEND_RENDER_TMP="$(mktemp -d)"
  mapfile -t FRONTEND_RENDERED_FILES < <(python3 - <<'PY'
from pathlib import Path

tokens = ["__ASSET_VERSION__", "__APP_BUNDLE_PATH__"]
for path in sorted(Path("jupiter-faucet-frontend/assets").rglob("*")):
    if not path.is_file():
        continue
    try:
        text = path.read_text()
    except UnicodeDecodeError:
        continue
    if any(token in text for token in tokens):
        print(path.as_posix())
PY
)

  local file backup_path backup_dir
  for file in "${FRONTEND_RENDERED_FILES[@]}"; do
    backup_path="${FRONTEND_RENDER_TMP}/${file}"
    backup_dir="$(dirname "$backup_path")"
    mkdir -p "$backup_dir"
    cp "$file" "$backup_path"
    python3 - "$file" "$FRONTEND_ASSET_TOKEN" "$asset_version" "$FRONTEND_BUNDLE_TOKEN" "$bundle_path" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
asset_token = sys.argv[2]
asset_value = sys.argv[3]
bundle_token = sys.argv[4]
bundle_value = sys.argv[5]
text = path.read_text()
text = text.replace(asset_token, asset_value).replace(bundle_token, bundle_value)
path.write_text(text)
PY
  done
}

restore_frontend_assets() {
  if [[ -n "$FRONTEND_RENDER_TMP" && -d "$FRONTEND_RENDER_TMP" ]]; then
    local file backup_path
    for file in "${FRONTEND_RENDERED_FILES[@]:-}"; do
      backup_path="${FRONTEND_RENDER_TMP}/${file}"
      if [[ -f "$backup_path" ]]; then
        cp "$backup_path" "$file"
      fi
    done

    rm -rf "$FRONTEND_RENDER_TMP"
  fi

  FRONTEND_RENDER_TMP=""
  FRONTEND_RENDERED_FILES=()
}

trap restore_frontend_assets EXIT

build_one() {
  local target_name="$1"
  local cargo_package="$2"
  local raw_name="$3"
  local candid_path="$4"
  local artifact_stem="$5"

  cargo build --locked --target wasm32-unknown-unknown --release -p "$cargo_package"

  local raw_in="target/wasm32-unknown-unknown/release/${raw_name}.wasm"
  local raw_out="release-artifacts/${artifact_stem}.wasm"
  local gz_out="release-artifacts/${artifact_stem}.wasm.gz"

  ic-wasm "$raw_in" -o "$raw_out" metadata candid:service -f "$candid_path" -v public
  ic-wasm "$raw_out" -o "$raw_out" shrink

  gzip -n -9 -c "$raw_out" > "$gz_out"

  sha256sum "$raw_out" > "${raw_out}.sha256"
  sha256sum "$gz_out" > "${gz_out}.sha256"

  echo "Built ${target_name}: ${raw_out} ${gz_out}"
}

build_selected() {
  case "$1" in
    jupiter-disburser)
      build_one "jupiter-disburser" "jupiter-disburser" "jupiter_disburser" "jupiter-disburser/jupiter_disburser.did" "jupiter_disburser"
      ;;
    jupiter-lifeline)
      build_one "jupiter-lifeline" "jupiter-lifeline" "jupiter_lifeline" "jupiter-lifeline/jupiter_lifeline.did" "jupiter_lifeline"
      ;;
    jupiter-faucet)
      build_one "jupiter-faucet" "jupiter-faucet" "jupiter_faucet" "jupiter-faucet/jupiter_faucet.did" "jupiter_faucet"
      ;;
    jupiter-historian)
      build_one "jupiter-historian" "jupiter-historian" "jupiter_historian" "jupiter-historian/jupiter_historian.did" "jupiter_historian"
      ;;
    jupiter-sns-rewards)
      build_one "jupiter-sns-rewards" "jupiter-sns-rewards" "jupiter_sns_rewards" "jupiter-sns-rewards/jupiter_sns_rewards.did" "jupiter_sns_rewards"
      ;;
    jupiter-faucet-frontend)
      build_frontend_bundle
      render_frontend_assets
      build_one "jupiter-faucet-frontend" "jupiter-faucet-frontend" "jupiter_faucet_frontend" "jupiter-faucet-frontend/jupiter_faucet_frontend.did" "jupiter_faucet_frontend"
      restore_frontend_assets
      ;;
    all)
      build_selected jupiter-disburser
      build_selected jupiter-lifeline
      build_selected jupiter-faucet
      build_selected jupiter-historian
      build_selected jupiter-sns-rewards
      build_selected jupiter-faucet-frontend
      ;;
    *)
      echo "unknown build target: $1" >&2
      echo "expected one of: jupiter-disburser, jupiter-lifeline, jupiter-faucet, jupiter-historian, jupiter-sns-rewards, jupiter-faucet-frontend, all" >&2
      exit 1
      ;;
  esac
}

TARGET="${1:-all}"
build_selected "$TARGET"
