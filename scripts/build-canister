#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

cd "$REPO_ROOT"

export TZ=UTC
export LC_ALL=C.UTF-8
export LANG=C.UTF-8

if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  export SOURCE_DATE_EPOCH="${SOURCE_DATE_EPOCH:-$(git log -1 --pretty=%ct)}"
else
  export SOURCE_DATE_EPOCH="${SOURCE_DATE_EPOCH:-1700000000}"
fi

export RUSTFLAGS="${RUSTFLAGS:-} --remap-path-prefix=${REPO_ROOT}=/build"

mkdir -p release-artifacts

FRONTEND_ASSET_TOKEN="__ASSET_VERSION__"
FRONTEND_RENDER_TMP=""
declare -a FRONTEND_RENDERED_FILES=()

compute_asset_version() {
  if [[ -n "${ASSET_VERSION:-}" ]]; then
    printf '%s\n' "$ASSET_VERSION"
    return
  fi

  local short_sha="nogit"
  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    short_sha="$(git rev-parse --short=12 HEAD)"
  fi

  SHORT_SHA="$short_sha" python3 - <<'PY'
import datetime
import os

epoch = int(os.environ.get("SOURCE_DATE_EPOCH", "1700000000"))
short_sha = os.environ.get("SHORT_SHA", "nogit")
date = datetime.datetime.fromtimestamp(epoch, tz=datetime.timezone.utc).strftime("%Y-%m-%d")
print(f"{date}-{short_sha}")
PY
}

render_frontend_assets() {
  local asset_version
  asset_version="$(compute_asset_version)"

  echo "Using jupiter-faucet-frontend asset version: ${asset_version}"

  FRONTEND_RENDER_TMP="$(mktemp -d)"
  mapfile -t FRONTEND_RENDERED_FILES < <(python3 - <<'PY'
from pathlib import Path

token = "__ASSET_VERSION__"
for path in sorted(Path("jupiter-faucet-frontend/assets").rglob("*")):
    if not path.is_file():
        continue
    try:
        text = path.read_text()
    except UnicodeDecodeError:
        continue
    if token in text:
        print(path.as_posix())
PY
)

  if [[ ${#FRONTEND_RENDERED_FILES[@]} -eq 0 ]]; then
    echo "warning: no frontend asset files contained ${FRONTEND_ASSET_TOKEN}" >&2
    return
  fi

  local file backup_path backup_dir
  for file in "${FRONTEND_RENDERED_FILES[@]}"; do
    backup_path="${FRONTEND_RENDER_TMP}/${file}"
    backup_dir="$(dirname "$backup_path")"
    mkdir -p "$backup_dir"
    cp "$file" "$backup_path"
    python3 - "$file" "$FRONTEND_ASSET_TOKEN" "$asset_version" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
token = sys.argv[2]
value = sys.argv[3]
path.write_text(path.read_text().replace(token, value))
PY
  done
}

restore_frontend_assets() {
  if [[ -n "$FRONTEND_RENDER_TMP" && -d "$FRONTEND_RENDER_TMP" ]]; then
    local file backup_path
    for file in "${FRONTEND_RENDERED_FILES[@]:-}"; do
      backup_path="${FRONTEND_RENDER_TMP}/${file}"
      if [[ -f "$backup_path" ]]; then
        cp "$backup_path" "$file"
      fi
    done

    rm -rf "$FRONTEND_RENDER_TMP"
  fi

  FRONTEND_RENDER_TMP=""
  FRONTEND_RENDERED_FILES=()
}

trap restore_frontend_assets EXIT

build_one() {
  local target_name="$1"
  local cargo_package="$2"
  local raw_name="$3"
  local candid_path="$4"
  local artifact_stem="$5"

  cargo build --locked --target wasm32-unknown-unknown --release -p "$cargo_package"

  local raw_in="target/wasm32-unknown-unknown/release/${raw_name}.wasm"
  local raw_out="release-artifacts/${artifact_stem}.wasm"
  local gz_out="release-artifacts/${artifact_stem}.wasm.gz"

  ic-wasm "$raw_in" -o "$raw_out" metadata candid:service -f "$candid_path" -v public
  ic-wasm "$raw_out" -o "$raw_out" shrink

  gzip -n -9 -c "$raw_out" > "$gz_out"

  sha256sum "$raw_out" > "${raw_out}.sha256"
  sha256sum "$gz_out" > "${gz_out}.sha256"

  echo "Built ${target_name}: ${raw_out} ${gz_out}"
}

build_selected() {
  case "$1" in
    jupiter-disburser)
      build_one "jupiter-disburser" "jupiter-disburser" "jupiter_disburser" "jupiter-disburser/jupiter_disburser.did" "jupiter_disburser"
      ;;
    jupiter-lifeline)
      build_one "jupiter-lifeline" "jupiter-lifeline" "jupiter_lifeline" "jupiter-lifeline/jupiter_lifeline.did" "jupiter_lifeline"
      ;;
    jupiter-faucet)
      build_one "jupiter-faucet" "jupiter-faucet" "jupiter_faucet" "jupiter-faucet/jupiter_faucet.did" "jupiter_faucet"
      ;;
    jupiter-historian)
      build_one "jupiter-historian" "jupiter-historian" "jupiter_historian" "jupiter-historian/jupiter_historian.did" "jupiter_historian"
      ;;
    jupiter-sns-rewards)
      build_one "jupiter-sns-rewards" "jupiter-sns-rewards" "jupiter_sns_rewards" "jupiter-sns-rewards/jupiter_sns_rewards.did" "jupiter_sns_rewards"
      ;;
    jupiter-faucet-frontend)
      render_frontend_assets
      build_one "jupiter-faucet-frontend" "jupiter-faucet-frontend" "jupiter_faucet_frontend" "jupiter-faucet-frontend/jupiter_faucet_frontend.did" "jupiter_faucet_frontend"
      restore_frontend_assets
      ;;
    all)
      build_selected jupiter-disburser
      build_selected jupiter-lifeline
      build_selected jupiter-faucet
      build_selected jupiter-historian
      build_selected jupiter-sns-rewards
      build_selected jupiter-faucet-frontend
      ;;
    *)
      echo "unknown build target: $1" >&2
      echo "expected one of: jupiter-disburser, jupiter-lifeline, jupiter-faucet, jupiter-historian, jupiter-sns-rewards, jupiter-faucet-frontend, all" >&2
      exit 1
      ;;
  esac
}

TARGET="${1:-all}"
build_selected "$TARGET"
