#!/usr/bin/env python3
import json
import re
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent

MAINNET = {
    "ledger": "ryjl3-tyaaa-aaaaa-aaaba-cai",
    "index": "qhbym-qaaaa-aaaaa-aaafq-cai",
    "governance": "rrkah-fqaaa-aaaaa-aaaaq-cai",
    "cmc": "rkp4c-7iaaa-aaaaa-aaaca-cai",
    "blackhole": "e3mmv-5qaaa-aaaah-aadma-cai",
    "sns_wasm": "qaa6y-5yaaa-aaaaa-aaafa-cai",
}

CANISTER_IDS = json.loads((REPO_ROOT / "canister_ids.json").read_text())
PROD = {
    "jupiter_disburser": CANISTER_IDS["jupiter_disburser"]["ic"],
    "jupiter_faucet": CANISTER_IDS["jupiter_faucet"]["ic"],
    "jupiter_historian": CANISTER_IDS["jupiter_historian"]["ic"],
    "jupiter_lifeline": CANISTER_IDS["jupiter_lifeline"]["ic"],
    "jupiter_sns_rewards": CANISTER_IDS["jupiter_sns_rewards"]["ic"],
}

EXPECTED_DQUORUM_SUBACCOUNT = (
    r'opt blob "\77\e6\3d\e7\2b\5e\33\39\ea\20\f4\ba\f3\ec\2b\d9\21\38\dd\de\0d\ae\b6\9d\b5\0a\cc\eb\38\4b\df\0f"'
)

EXPECTED_STAKING_SUBACCOUNT = (
    r'opt blob "\ff\0c\0b\36\af\ef\ff\d0\c7\a4\d8\5c\0b\ce\a3\66\ac\d6\d7\4f\45\f7\70\3d\07\83\cc\64\48\89\9c\68"'
)


def fail(msg: str) -> None:
    print(f"mainnet install-args validation failed: {msg}", file=sys.stderr)
    sys.exit(1)


def require_contains(text: str, needle: str, context: str) -> None:
    if needle not in text:
        fail(f"{context} is missing `{needle}`")


def extract_nat64(text: str, field: str, path: Path) -> int:
    match = re.search(rf"{re.escape(field)}\s*=\s*(?:opt\s*)?(?:\()?\s*(\d+)(?:\s*:\s*nat64)?\s*\)?\s*;", text)
    if not match:
        fail(f"{path} is missing `{field}`")
    return int(match.group(1))


def validate_no_debug_methods_in_prod_did(path: Path) -> None:
    text = path.read_text()
    if re.search(r"\bdebug_\w+\b", text):
        fail(f"{path} unexpectedly exposes debug_* methods in the production DID")


def validate_debug_methods_present_in_debug_did(path: Path) -> None:
    text = path.read_text()
    if not re.search(r"\bdebug_\w+\b", text):
        fail(f"{path} is expected to expose debug_* methods")


def validate_disburser() -> None:
    path = REPO_ROOT / "jupiter-disburser" / "mainnet-install-args.did"
    text = path.read_text()
    require_contains(text, 'neuron_id = 11614578985374291210 : nat64;', str(path))
    require_contains(text, f'owner = principal "{PROD["jupiter_faucet"]}";', str(path))
    require_contains(text, f'owner = principal "{PROD["jupiter_sns_rewards"]}";', str(path))
    require_contains(text, f'owner = principal "{MAINNET["governance"]}";', str(path))
    require_contains(text, f'subaccount = {EXPECTED_DQUORUM_SUBACCOUNT};', str(path))
    require_contains(text, f'ledger_canister_id = opt principal "{MAINNET["ledger"]}";', str(path))
    require_contains(text, f'governance_canister_id = opt principal "{MAINNET["governance"]}";', str(path))
    require_contains(text, f'rescue_controller = principal "{PROD["jupiter_lifeline"]}";', str(path))
    require_contains(text, f'blackhole_controller = opt principal "{MAINNET["blackhole"]}";', str(path))


def validate_faucet() -> int:
    path = REPO_ROOT / "jupiter-faucet" / "mainnet-install-args.did"
    text = path.read_text()
    require_contains(text, f'owner = principal "{MAINNET["governance"]}";', str(path))
    require_contains(text, f'subaccount = {EXPECTED_STAKING_SUBACCOUNT};', str(path))
    require_contains(text, f'ledger_canister_id = opt principal "{MAINNET["ledger"]}";', str(path))
    require_contains(text, f'index_canister_id = opt principal "{MAINNET["index"]}";', str(path))
    require_contains(text, f'cmc_canister_id = opt principal "{MAINNET["cmc"]}";', str(path))
    require_contains(text, f'rescue_controller = principal "{PROD["jupiter_lifeline"]}";', str(path))
    require_contains(text, f'blackhole_controller = opt principal "{MAINNET["blackhole"]}";', str(path))

    match = re.search(r"expected_first_staking_tx_id\s*=\s*([^;]+);", text)
    if not match:
        fail(f"{path} is missing `expected_first_staking_tx_id`")
    value = match.group(1).strip()
    faucet_min_tx_e8s = extract_nat64(text, "min_tx_e8s", path)
    if faucet_min_tx_e8s < 10_000_000:
        fail(f"{path} configures min_tx_e8s below the supported floor of 10_000_000 e8s (0.1 ICP)")
    if value == "null":
        return faucet_min_tx_e8s
    if re.fullmatch(r"opt\s+\(?\s*\d+(?:\s*:\s*nat64)?\s*\)?", value):
        return faucet_min_tx_e8s
    fail(
        f"{path} has invalid `expected_first_staking_tx_id` value `{value}`; expected `null` or `opt <nat64>`"
    )


def validate_historian() -> int:
    path = REPO_ROOT / "jupiter-historian" / "mainnet-install-args.did"
    text = path.read_text()
    require_contains(text, f'owner = principal "{MAINNET["governance"]}";', str(path))
    require_contains(text, f'subaccount = {EXPECTED_STAKING_SUBACCOUNT};', str(path))
    require_contains(text, f'ledger_canister_id = opt principal "{MAINNET["ledger"]}";', str(path))
    require_contains(text, f'index_canister_id = opt principal "{MAINNET["index"]}";', str(path))
    require_contains(text, f'cmc_canister_id = opt principal "{MAINNET["cmc"]}";', str(path))
    require_contains(text, f'faucet_canister_id = opt principal "{PROD["jupiter_faucet"]}";', str(path))
    require_contains(text, f'blackhole_canister_id = opt principal "{MAINNET["blackhole"]}";', str(path))
    require_contains(text, f'sns_wasm_canister_id = opt principal "{MAINNET["sns_wasm"]}";', str(path))
    historian_min_tx_e8s = extract_nat64(text, "min_tx_e8s", path)
    if historian_min_tx_e8s < 10_000_000:
        fail(f"{path} configures min_tx_e8s below the supported floor of 10_000_000 e8s (0.1 ICP)")
    return historian_min_tx_e8s


def main() -> None:
    validate_disburser()
    faucet_min_tx_e8s = validate_faucet()
    historian_min_tx_e8s = validate_historian()
    if faucet_min_tx_e8s != historian_min_tx_e8s:
        fail(
            f"faucet/historian min_tx_e8s mismatch: faucet={faucet_min_tx_e8s} historian={historian_min_tx_e8s}"
        )

    validate_no_debug_methods_in_prod_did(REPO_ROOT / "jupiter-faucet" / "jupiter_faucet.did")
    validate_no_debug_methods_in_prod_did(REPO_ROOT / "jupiter-disburser" / "jupiter_disburser.did")
    validate_no_debug_methods_in_prod_did(REPO_ROOT / "jupiter-historian" / "jupiter_historian.did")
    validate_debug_methods_present_in_debug_did(REPO_ROOT / "jupiter-faucet" / "jupiter_faucet_debug.did")
    validate_debug_methods_present_in_debug_did(REPO_ROOT / "jupiter-disburser" / "jupiter_disburser_debug.did")
    validate_debug_methods_present_in_debug_did(REPO_ROOT / "jupiter-historian" / "jupiter_historian_debug.did")
    print("mainnet install-args and DID validation OK")


if __name__ == "__main__":
    main()
