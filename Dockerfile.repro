FROM debian:bookworm-slim@sha256:74d56e3931e0d5a1dd51f8c8a2466d21de84a271cd3b5a733b803aa91abf4421 AS builder

ENV DEBIAN_FRONTEND=noninteractive
ENV PATH="/root/.cargo/bin:${PATH}"

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        curl \
        git \
        gzip \
        nodejs \
        npm \
        xz-utils \
    && rm -rf /var/lib/apt/lists/*

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --profile minimal --default-toolchain 1.94.0

RUN rustup target add wasm32-unknown-unknown --toolchain 1.94.0
RUN cargo install ic-wasm --version 0.9.7 --locked

WORKDIR /build
COPY . /build
RUN chmod +x /build/scripts/build-canister
RUN /build/scripts/build-canister

FROM scratch AS artifact
COPY --from=builder /build/release-artifacts/ /release-artifacts/

