{
  "name": "jupiter-faucet-suite",
  "private": true,
  "type": "module",
  "scripts": {
    "build:frontend": "node jupiter-faucet-frontend/frontend-src/build-frontend.mjs",
    "setup:frontend": "npm ci --no-fund --no-audit --silent",
    "test:frontend-dashboard": "node --test jupiter-faucet-frontend/frontend-src/test/dashboard-data.test.mjs",
    "test:frontend-neuron": "node --test jupiter-faucet-frontend/frontend-src/test/neuron-details-controller.test.mjs",
    "test:frontend-unit": "node --test jupiter-faucet-frontend/frontend-src/test/*.test.mjs",
    "test:frontend-dashboard-local": "node --test jupiter-faucet-frontend/frontend-src/test/dashboard-data.local-replica.test.mjs",
    "verify:reproducible-artifacts": "bash ./scripts/verify-reproducible-artifacts"
  },
  "dependencies": {
    "@icp-sdk/core": "5.0.0",
    "@noble/hashes": "1.8.0"
  },
  "devDependencies": {
    "esbuild": "0.27.4"
  }
}
