{
  "name": "jupiter-faucet-suite",
  "private": true,
  "type": "module",
  "scripts": {
    "build:frontend": "node canisters/frontend/web/build-frontend.mjs",
    "setup:frontend": "npm ci --no-fund --no-audit --silent",
    "test:frontend-dashboard": "node --test canisters/frontend/web/test/dashboard-data.test.mjs",
    "test:frontend-neuron": "node --test canisters/frontend/web/test/neuron-details-controller.test.mjs",
    "test:frontend-unit": "node --test canisters/frontend/web/test/*.test.mjs",
    "test:frontend-dashboard-local": "node --test canisters/frontend/web/test/dashboard-data.local-replica.test.mjs",
    "lint:frontend-exports": "node tools/scripts/check-frontend-exports.mjs",
    "security:scan": "./tools/scripts/security-scan",
    "sbom": "./tools/scripts/security-scan",
    "verify:reproducible-artifacts": "bash ./tools/scripts/verify-reproducible-artifacts"
  },
  "dependencies": {
    "@icp-sdk/core": "5.0.0",
    "@noble/hashes": "1.8.0"
  },
  "devDependencies": {
    "esbuild": "0.27.4"
  }
}
